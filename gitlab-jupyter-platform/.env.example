# =========================================================================
# Cấu hình cục bộ GitLab & JupyterHub
# =========================================================================

# Docker Image của GitLab (Nên dùng tag phiên bản cụ thể, KHÔNG dùng latest)
# Ví dụ: gitlab/gitlab-ce:17.0.2-ce.0
GITLAB_IMAGE=gitlab/gitlab-ce:17.0.2-ce.0

# Tên miền ảo (Hostname) của GitLab
GITLAB_HOST=gitlab.local

# Các cổng ánh xạ ra máy Host (Windows)
GITLAB_HTTP_PORT=8929
GITLAB_SSH_PORT=2424

# Mật khẩu Root ban đầu (chỉ sử dụng cho lần khởi tạo đầu tiên)
# Lưu ý: Tránh mật khẩu chứa từ khóa "gitlab" để không bị lỗi bảo mật
GITLAB_ROOT_PASSWORD=SuperSecretPassword123!

# =========================================================================
# Đường dẫn lưu trữ dữ liệu (Mount từ WSL2 / Ổ D Windows)
# Hãy điều chỉnh nếu đường dẫn thực tế của bạn khác.
# Lưu ý: GITLAB_DATA_DIR bắt buộc để ở thư mục ext4 nội bộ của WSL2
# (ví dụ: /home/huynhduc/...) để tránh lỗi phân quyền NTFS (Operation not permitted).
# =========================================================================
GITLAB_CONFIG_DIR=/mnt/d/NCKH/e-learning/gitlab-jupyter-platform/gitlab/config
GITLAB_LOGS_DIR=/mnt/d/NCKH/e-learning/gitlab-jupyter-platform/gitlab/logs
GITLAB_DATA_DIR=/mnt/d/NCKH/e-learning/gitlab-jupyter-platform/gitlab/data
MINIO_DATA_DIR=/mnt/d/NCKH/e-learning/gitlab-jupyter-platform/minio/data

# =========================================================================
# Cấu hình Cơ sở dữ liệu (PostgreSQL) & Redis
# =========================================================================
# USE_EXTERNAL_DB_REDIS:
# - false (Mặc định): Sử dụng PostgreSQL & Redis tích hợp sẵn bên trong container GitLab.
# - true: Sử dụng PostgreSQL & Redis dùng chung ngoài từ stack 'infra-data'.
USE_EXTERNAL_DB_REDIS=false

# Cấu hình PostgreSQL ngoài (Chỉ áp dụng nếu USE_EXTERNAL_DB_REDIS=true)
EXTERNAL_DB_HOST=infra-postgres
EXTERNAL_DB_PORT=5432
EXTERNAL_DB_NAME=gitlabhq_production
EXTERNAL_DB_USER=gitlab
EXTERNAL_DB_PASSWORD=gitlab_password

# Cấu hình Redis ngoài (Chỉ áp dụng nếu USE_EXTERNAL_DB_REDIS=true)
EXTERNAL_REDIS_HOST=infra-redis
EXTERNAL_REDIS_PORT=6379
EXTERNAL_REDIS_PASSWORD=redis_password

# =========================================================================
# Cấu hình MinIO (Kho lưu trữ Object Storage / Giả lập S3)
# =========================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
