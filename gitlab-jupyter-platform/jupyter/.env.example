# =====================================================================
# Cấu hình Port & URL của JupyterHub mới
# =====================================================================
JUPYTERHUB_HOST_PORT=18010
JUPYTERHUB_PUBLIC_URL=http://localhost:18010

# =====================================================================
# Cấu hình GitLab OAuth
# =====================================================================
GITLAB_URL=http://gitlab.local:8929
GITLAB_CLIENT_ID=your_gitlab_client_id_here
GITLAB_CLIENT_SECRET=your_gitlab_client_secret_here
GITLAB_OAUTH_CALLBACK_URL=http://localhost:18010/hub/oauth_callback

# =====================================================================
# Cấu hình User và Phân quyền
# =====================================================================
JUPYTERHUB_ADMIN_USERS=root,admin
JUPYTERHUB_ALLOWED_USERS=

# =====================================================================
# Cấu hình Docker Spawner & Networking
# =====================================================================
DOCKER_NETWORK_NAME=gitlab-jupyter-net
SINGLEUSER_IMAGE=gitlab-jupyter-singleuser:latest
JUPYTERHUB_COOKIE_SECRET=  # Tạo mã Hex ngẫu nhiên bằng lệnh: openssl rand -hex 32

# =====================================================================
# Cấu hình Tự động Clone Bài Lab (Phase 2B)
# =====================================================================
GITLAB_AUTOCLONE_ENABLED=true
GITLAB_AUTOCLONE_FETCH_EXISTING=false
JUPYTERHUB_CRYPT_KEY=  # Tạo mã Hex ngẫu nhiên bằng lệnh: openssl rand -hex 32

