# =====================================================================
# Project Configuration
# =====================================================================
PROJECT_NAME=sso-stack
TZ=Asia/Ho_Chi_Minh

# Keycloak Version to download and build (e.g. 24.0.5, 25.0.2, 26.0.0)
KEYCLOAK_VERSION=24.0.5

# =====================================================================
# Host Ports Mapping (to avoid local conflicts)
# =====================================================================
LDAP_HOST_PORT=1389
KEYCLOAK_HOST_PORT=18090
LDAP_ADMIN_HOST_PORT=18091

# =====================================================================
# OpenLDAP Configuration
# =====================================================================
LDAP_DOMAIN=school.local
LDAP_ORGANIZATION="School Local"
LDAP_BASE_DN=dc=school,dc=local
LDAP_ADMIN_PASSWORD=adminpwd123

# Test User Passwords
SV001_PASSWORD=student123
TEACHER01_PASSWORD=teacher123

# =====================================================================
# Shared PostgreSQL Database (from infra-data)
# =====================================================================
POSTGRES_HOST=infra-postgres
POSTGRES_PORT=5432
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak_user
KEYCLOAK_DB_PASSWORD=keycloak_db_pass123

# =====================================================================
# Keycloak Administration Bootstrap
# =====================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=adminpwd123

# =====================================================================
# Client Integration Configuration (Public URLs)
# =====================================================================
MOODLE_WWWROOT=http://moodle.school.local:18080
GITLAB_URL=http://gitlab.school.local:18088
JUPYTERHUB_URL=http://jupyterhub.school.local:18000
OPENWEBUI_URL=http://localhost:3000

# Client Secrets for OpenID Connect (OIDC)
MOODLE_OIDC_CLIENT_SECRET=moodle-secret-123
GITLAB_OIDC_CLIENT_SECRET=gitlab-secret-123
JUPYTERHUB_OIDC_CLIENT_SECRET=jupyterhub-secret-123
OPENWEBUI_OIDC_CLIENT_SECRET=openwebui-secret-123


# =====================================================================
# Keycloak Hostname Configuration
# =====================================================================
KC_HOSTNAME_URL=http://keycloak.school.local:18090
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_HTTPS=false
KC_HTTP_ENABLED=true

# =====================================================================
# GitLab Identity Provider (Keycloak broker cho nút "Đăng nhập với GitLab")
# =====================================================================
# Tạo tại: GITLAB_URL/admin/applications
# Redirect URI: KC_HOSTNAME_URL/realms/school/broker/gitlab/endpoint
# Scopes: api, read_user, openid, profile, email
GITLAB_OAUTH_APP_ID=
GITLAB_OAUTH_APP_SECRET=
