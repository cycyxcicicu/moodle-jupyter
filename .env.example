# =====================================================================
# Project Configuration
# =====================================================================
PROJECT_NAME=moodle-jupyter-platform
TZ=Asia/Ho_Chi_Minh
DATA_ROOT=/mnt/d/NCKH/e-learning/moodle-jupyter-platform

# =====================================================================
# Host Ports Mapping (to avoid local conflicts)
# =====================================================================
MOODLE_HOST_PORT=18080
JUPYTERHUB_HOST_PORT=18000
POSTGRES_HOST_PORT=15434

# =====================================================================
# URLs Configuration (Browser public URLs)
# =====================================================================
MOODLE_WWWROOT=http://localhost:18080
JUPYTERHUB_URL=http://localhost:18000

# =====================================================================
# PostgreSQL Database Service Configuration
# =====================================================================
POSTGRES_HOST=infra-postgres
POSTGRES_PORT=5432
POSTGRES_ADMIN_USER=postgres_user
POSTGRES_ADMIN_PASSWORD=postgres_password
POSTGRES_DB=postgres_app_db

# =====================================================================
# Moodle Database Configuration
# =====================================================================
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle_user
MOODLE_DB_PASSWORD=moodle_password

# =====================================================================
# JupyterHub Database Configuration
# =====================================================================
JUPYTERHUB_DB_NAME=jupyterhub
JUPYTERHUB_DB_USER=jupyterhub_user
JUPYTERHUB_DB_PASSWORD=jupyterhub_password
JUPYTERHUB_DB_URL=postgresql://jupyterhub_user:jupyterhub_password@infra-postgres:5432/jupyterhub

# =====================================================================
# Moodle Admin Configuration
# =====================================================================
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=admin123
MOODLE_ADMIN_EMAIL=admin@example.com
MOODLE_DATA_ROOT=/var/moodledata
MOODLE_LANG=en


# =====================================================================
# LTI Configuration
# =====================================================================
LTI_USERNAME_KEY=email
JUPYTERHUB_COOKIE_SECURE=false
JUPYTERHUB_COOKIE_SAMESITE=Lax
