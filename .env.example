# =====================================================================
# Project Configuration
# =====================================================================
PROJECT_NAME=moodle-jupyter-platform
TZ=Asia/Ho_Chi_Minh
DATA_ROOT=/mnt/d/NCKH/e-learning/moodle-jupyter-platform

# =====================================================================
# Host Ports Mapping (to avoid local conflicts)
# =====================================================================
MOODLE_HOST_PORT=18080
JUPYTERHUB_HOST_PORT=18000
POSTGRES_HOST_PORT=15434

# =====================================================================
# URLs Configuration (Browser public URLs)
# =====================================================================
MOODLE_WWWROOT=http://moodle.school.local:18080
JUPYTERHUB_URL=http://jupyterhub.school.local:18000

# =====================================================================
# Keycloak SSO Integration
# =====================================================================
KEYCLOAK_ISSUER=http://keycloak.school.local:18090/realms/school
MOODLE_OIDC_CLIENT_ID=moodle-client
MOODLE_OIDC_CLIENT_SECRET=moodle-secret-123
JUPYTERHUB_OIDC_CLIENT_SECRET=jupyterhub-secret-123

# =====================================================================
# PostgreSQL Database Service Configuration
# =====================================================================
POSTGRES_HOST=infra-postgres
POSTGRES_PORT=5432
POSTGRES_ADMIN_USER=postgres_user
POSTGRES_ADMIN_PASSWORD=postgres_password
POSTGRES_DB=postgres_app_db

# =====================================================================
# Moodle Database Configuration
# =====================================================================
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle_user
MOODLE_DB_PASSWORD=moodle_password

# =====================================================================
# JupyterHub Database Configuration
# =====================================================================
JUPYTERHUB_DB_NAME=jupyterhub
JUPYTERHUB_DB_USER=jupyterhub_user
JUPYTERHUB_DB_PASSWORD=jupyterhub_password
JUPYTERHUB_DB_URL=postgresql://jupyterhub_user:jupyterhub_password@infra-postgres:5432/jupyterhub

# =====================================================================
# Moodle Admin Configuration
# =====================================================================
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=admin123
MOODLE_ADMIN_EMAIL=admin@example.com
MOODLE_DATA_ROOT=/var/moodledata
MOODLE_LANG=en


# =====================================================================
# LTI Configuration
# =====================================================================
LTI_USERNAME_KEY=email
JUPYTERHUB_COOKIE_SECURE=false
JUPYTERHUB_COOKIE_SAMESITE=Lax

# =====================================================================
# JupyterHub API Token Configuration
# =====================================================================
JUPYTERHUB_API_TOKEN=super-secret-token

# Khóa mã hóa auth_state (bắt buộc để lưu id_token cho SSO logout)
# Tạo bằng: openssl rand -hex 32
JUPYTERHUB_CRYPT_KEY=

# =====================================================================
# Assignment Service Database Configuration
# =====================================================================
ASSIGNMENT_DB_HOST=infra-postgres
ASSIGNMENT_DB_PORT=5432
ASSIGNMENT_DB_NAME=assignment_service
ASSIGNMENT_DB_USER=assignment_user
ASSIGNMENT_DB_PASSWORD=moodle_jupyter_assign_pass
ASSIGNMENT_DATABASE_URL=postgresql://assignment_user:moodle_jupyter_assign_pass@infra-postgres:5432/assignment_service

# =====================================================================
# GitLab Integration (for JupyterHub impersonation token)
# =====================================================================
# URL công khai của GitLab (trùng với GITLAB_URL trong gitlab-jupyter-platform/.env)
GITLAB_URL=http://gitlab.school.local:18088
# Personal Access Token của root user GitLab (cần scope: api, sudo)
# Tạo tại: GitLab → User Settings → Access Tokens
GITLAB_ADMIN_TOKEN=your-gitlab-root-token-here
# Tự động clone repo GitLab khi user đăng nhập trực tiếp vào JupyterHub
GITLAB_AUTOCLONE_ENABLED=true
# Khi repo đã tồn tại: true = git fetch, false = bỏ qua
GITLAB_AUTOCLONE_FETCH_EXISTING=false

# =====================================================================
# User Container Resource Limits
# =====================================================================
JUPYTERHUB_USER_MEM_LIMIT=1G
JUPYTERHUB_USER_CPU_LIMIT=1.0
